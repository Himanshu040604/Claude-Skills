{
  "test_file_patterns": [
    "(^|/)test_[^/]*$",
    "(^|/)[^/]*_test\\.[a-zA-Z]+$",
    "(^|/)[^/]*\\.test\\.[a-zA-Z]+$",
    "(^|/)tests?/",
    "(^|/)spec/",
    "(^|/)[^/]*_spec\\.[a-zA-Z]+$",
    "(^|/)conftest\\.py$"
  ],
  "patterns": [
    {"category": "test-skip", "severity": "high", "applies_to": "added",
     "regex": "@(pytest\\.mark\\.(skip|xfail)|unittest\\.skip)",
     "description": "added a skip/xfail marker"},
    {"category": "test-skip", "severity": "high", "applies_to": "added",
     "regex": "\\.(skip|only)\\s*\\(",
     "description": "added .skip( or .only( test isolation"},
    {"category": "test-skip", "severity": "high", "applies_to": "added",
     "regex": "\\b(xit|xdescribe)\\s*\\(",
     "description": "added xit/xdescribe (disabled test)"},
    {"category": "test-skip", "severity": "medium", "applies_to": "added",
     "regex": "\\bt\\.Skip\\s*\\(",
     "description": "added t.Skip() (Go test skip)"},
    {"category": "test-skip", "severity": "medium", "applies_to": "added",
     "regex": "@Disabled\\b",
     "description": "added @Disabled (JUnit)"},
    {"category": "trivial-assert", "severity": "high", "applies_to": "added",
     "regex": "\\bassert\\s+(True|1)\\s*($|,|#)",
     "description": "added a trivially-true assertion"},
    {"category": "trivial-assert", "severity": "high", "applies_to": "added",
     "regex": "\\bassert\\b.*\\bor\\s+True\\b",
     "description": "assertion weakened with 'or True'"},
    {"category": "trivial-assert", "severity": "medium", "applies_to": "added",
     "regex": "expect\\s*\\(\\s*true\\s*\\)",
     "description": "added expect(true)"},
    {"category": "assertion-removed", "severity": "medium", "applies_to": "removed",
     "regex": "\\bassert(Equal|True|False|Raises|That)?\\b",
     "description": "removed an assertion"},
    {"category": "assertion-removed", "severity": "medium", "applies_to": "removed",
     "regex": "\\bexpect\\s*\\(",
     "description": "removed an expect() assertion"},
    {"category": "error-swallow", "severity": "high", "applies_to": "added",
     "regex": "except[^\\n]*:\\s*pass\\b",
     "description": "added except: pass (swallows the error)"},
    {"category": "error-swallow", "severity": "medium", "applies_to": "added",
     "regex": "catch\\s*\\([^)]*\\)\\s*\\{\\s*\\}",
     "description": "added an empty catch block"},
    {"category": "error-swallow", "severity": "low", "applies_to": "added",
     "regex": "#\\s*type:\\s*ignore|@ts-ignore|#\\s*noqa\\b",
     "description": "added an error-suppression comment"},
    {"category": "error-swallow", "severity": "medium", "applies_to": "added",
     "regex": "\\brescue\\s+nil\\b",
     "description": "added rescue nil (Ruby error swallow)"},
    {"category": "test-deleted", "severity": "high", "applies_to": "removed",
     "regex": "\\bdef\\s+test_\\w+",
     "description": "removed a test function"},
    {"category": "test-deleted", "severity": "medium", "applies_to": "removed",
     "regex": "\\b(it|test)\\s*\\(\\s*['\\\"]",
     "description": "removed an it()/test() case"},
    {"category": "test-deleted", "severity": "medium", "applies_to": "removed",
     "regex": "\\bfunc\\s+Test\\w+",
     "description": "removed a Go test function"}
  ]
}
