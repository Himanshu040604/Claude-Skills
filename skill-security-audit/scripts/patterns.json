{
  "patterns": [
    {"category": "dangerous-shell", "severity": "critical",
     "regex": "(curl|wget)\\s+[^|&;]*[|]\\s*(ba)?sh\\b",
     "description": "pipes a remote download directly into a shell"},
    {"category": "dangerous-shell", "severity": "high",
     "regex": "(curl|wget)\\b.*&&.*\\b(ba)?sh\\b",
     "description": "downloads then runs via && (download-and-execute)"},
    {"category": "dangerous-shell", "severity": "critical",
     "regex": "/dev/tcp/",
     "description": "bash /dev/tcp reverse-shell primitive"},
    {"category": "dangerous-shell", "severity": "critical",
     "regex": "\\bnc\\b[^\\n]*\\s-e\\b",
     "description": "netcat with -e (reverse shell)"},
    {"category": "dangerous-shell", "severity": "high",
     "regex": "\\brm\\s+-rf\\s+[~/]",
     "description": "recursive force-delete of a root or home path"},
    {"category": "dangerous-shell", "severity": "medium",
     "regex": "\\bmkfifo\\b",
     "description": "named-pipe creation (used in reverse shells)"},
    {"category": "obfuscation", "severity": "high",
     "regex": "base64\\s+(-d|--decode|-D)",
     "description": "base64 decoding (often hides a payload)"},
    {"category": "obfuscation", "severity": "high",
     "regex": "\\beval\\s*\\(",
     "description": "dynamic eval of code"},
    {"category": "obfuscation", "severity": "medium",
     "regex": "(\\\\x[0-9a-fA-F]{2}){4,}",
     "description": "long hex-encoded byte string"},
    {"category": "credential-exfil", "severity": "critical",
     "regex": "~/\\.(ssh|aws|netrc|gnupg)\\b",
     "description": "access to a credentials directory"},
    {"category": "credential-exfil", "severity": "high",
     "regex": "(AWS_SECRET|API_KEY|ACCESS_TOKEN|SECRET_KEY|PRIVATE_KEY)",
     "description": "reference to a secret environment variable"},
    {"category": "credential-exfil", "severity": "medium",
     "regex": "os\\.environ|process\\.env",
     "description": "bulk environment-variable access"},
    {"category": "suspicious-network", "severity": "high",
     "regex": "(webhook\\.site|ngrok\\.io|pipedream\\.net|requestbin)",
     "description": "request-capture / tunneling service endpoint"},
    {"category": "suspicious-network", "severity": "high",
     "regex": "\\.onion\\b",
     "description": "Tor hidden-service address"},
    {"category": "suspicious-network", "severity": "medium",
     "regex": "https?://\\d{1,3}(\\.\\d{1,3}){3}",
     "description": "hard-coded raw IP URL"},
    {"category": "suspicious-network", "severity": "low",
     "regex": "(pastebin\\.com|paste\\.ee|hastebin)",
     "description": "paste service (possible payload host)"},
    {"category": "install-hooks", "severity": "medium",
     "regex": "\"(preinstall|postinstall|prepare)\"\\s*:",
     "description": "npm lifecycle install hook"},
    {"category": "install-hooks", "severity": "medium",
     "regex": "\\bpip\\s+install\\b|\\bnpm\\s+install\\b",
     "description": "runtime package installation"},
    {"category": "prompt-injection-phrases", "severity": "high",
     "regex": "(?i)ignore\\s+(all\\s+)?(previous|prior|above)\\s+instructions",
     "description": "instruction-override phrase"},
    {"category": "prompt-injection-phrases", "severity": "high",
     "regex": "(?i)do\\s+not\\s+(tell|inform|mention\\s+to)\\s+the\\s+user",
     "description": "instructs Claude to hide actions from the user"},
    {"category": "prompt-injection-phrases", "severity": "medium",
     "regex": "(?i)(disregard|override)\\s+(your\\s+|the\\s+)?(safety|guidelines|system)",
     "description": "instructs Claude to override safety behavior"},
    {"category": "prompt-injection-phrases", "severity": "medium",
     "regex": "(?i)without\\s+(asking|telling|notifying)\\s+the\\s+user",
     "description": "instructs Claude to act without user consent"},
    {"category": "unicode-tricks", "severity": "high",
     "regex": "[\\u200b\\u200c\\u200d\\u2060\\ufeff]",
     "description": "zero-width / invisible character"},
    {"category": "unicode-tricks", "severity": "high",
     "regex": "[\\u202a-\\u202e\\u2066-\\u2069]",
     "description": "Unicode bidirectional control character"}
  ]
}
